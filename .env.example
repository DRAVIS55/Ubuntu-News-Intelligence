# African News Intelligence Platform — Environment Configuration (Django)
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://anip_user:your_password@localhost:5432/african_news_intel
# For SQLite (development/testing only):
# DATABASE_URL=sqlite:///african_news_intel.db

# ─── Vector Database ──────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: anthropic | openai | local
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Local model (llama.cpp — sovereign deployment)
LOCAL_MODEL_PATH=./models/mistral-7b.gguf
LOCAL_MODEL_N_CTX=8192
LOCAL_MODEL_N_GPU_LAYERS=0  # Set to 35 for GPU acceleration

# ─── External Data APIs ───────────────────────────────────────────────────────
WORLD_BANK_API_KEY=
NEWS_API_KEY=your-newsapi-key-here

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DJANGO_ENV=development
DEBUG=true
PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Ingestion ────────────────────────────────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_RUN=200

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# For multilingual (Swahili support):
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── Pattern Detection ────────────────────────────────────────────────────────
PATTERN_DETECTION_WINDOW_DAYS=30
PATTERN_MIN_OCCURRENCES=3

# ─── Security ─────────────────────────────────────────────────────────────────
API_RATE_LIMIT=100 per hour
ADMIN_TOKEN=change-this-admin-token

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/anip.log
